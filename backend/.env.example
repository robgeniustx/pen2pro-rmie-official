# ── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-key-here

# ── Model overrides (optional — defaults to gpt-4o-mini) ──
OPENAI_MODEL_FREE=gpt-4o-mini
OPENAI_MODEL_PRO=gpt-4o-mini
OPENAI_MODEL_ELITE=gpt-4o-mini
OPENAI_MODEL_STRATEGIST=gpt-4o-mini

# ── Stripe (optional until payments go live) ─────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ELITE=price_...
STRIPE_PRICE_FOUNDER=price_...

# ── MongoDB (optional — falls back to in-memory) ─────────────
MONGODB_URL=mongodb+srv://user:pass@cluster.mongodb.net/
MONGODB_DB_NAME=pen2pro

# ── App settings ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
# Production: FRONTEND_URL=https://pen2pro.com

# ── CORS (production only) ───────────────────────────────────
# ALLOWED_ORIGINS=https://pen2pro.com,https://www.pen2pro.com

# ── Waitlist ─────────────────────────────────────────────────
# SITE_LAUNCH_DATE=2025-06-01

# ── Auth ─────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-strong-random-secret-here
JWT_EXPIRE_MINUTES=10080
